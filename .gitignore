```gitignore
# Dependencies
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
.coverage
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Python cache
__pycache__/
*.py[cod]
*$py.class
*$pyc.class

# MyPy cache
.mypy_cache/
```