```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.o
*.obj
*.so
*.dll
*.exe

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Build/dist directories
build/
dist/
*.egg-info/

# Logs and temporary files
*.log
*.tmp
*.swp

# Editors/IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage
.coverage
coverage/
htmlcov/

# OS specific
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.coverage*/
```